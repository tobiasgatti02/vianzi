    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/form-data": "^2.5.0",
    "prisma": "^5.15.1",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
