{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "types": ["node"]
  },
  "include": ["src", "api"],
  "exclude": ["node_modules", "dist"]
}
