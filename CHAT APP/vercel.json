{
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "NODE_OPTIONS": "--enable-source-maps"
  },
  "rewrites": [
    { "source": "/(healthz)", "destination": "/api/$1" },
    { "source": "/(webhook.*)", "destination": "/api/$1" },
    { "source": "/(leads.*)", "destination": "/api/$1" },
    { "source": "/(messages.*)", "destination": "/api/$1" },
    { "source": "/(audio.*)", "destination": "/api/$1" }
  ]
}
